{
  "name": "luma-client",
  "version": "1.0.13",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1"
  },
  "build": {
    "appId": "com.myapp.electron",
    "productName": "Luma Client",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "SenkoUEFN",
        "repo": "Luma-Client-Starblast.io",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "images/icon.ico"
    }
  }
}
